{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wp0_report.schema.json",
  "title": "WP0 Healthcheck Report",
  "type": "object",
  "required": ["schema_version", "generated_at_utc", "system", "artifacts", "sections", "overall", "issues"],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at_utc": {"type": "string"},
    "system": {
      "type": "object",
      "required": ["timestamp_utc", "git_commit_hash", "ros_distro", "ubuntu_version", "wsl2", "gpu_driver"],
      "properties": {
        "timestamp_utc": {"type": ["string", "null"]},
        "git_commit_hash": {"type": ["string", "null"]},
        "ros_distro": {"type": ["string", "null"]},
        "ubuntu_version": {"type": ["string", "null"]},
        "wsl2": {"type": "boolean"},
        "gpu_driver": {"type": ["object", "null"]}
      },
      "additionalProperties": true
    },
    "sections": {
      "type": "object",
      "properties": {
        "camera_contract": {"$ref": "#/$defs/section"},
        "tf_contract": {"$ref": "#/$defs/section"},
        "approx_sync": {"$ref": "#/$defs/section"},
        "tray_stability": {"$ref": "#/$defs/section"},
        "state_latency": {"$ref": "#/$defs/section"},
        "rosbag_replay": {"$ref": "#/$defs/section"}
      },
      "required": ["camera_contract", "tf_contract", "approx_sync", "tray_stability", "state_latency", "rosbag_replay"],
      "additionalProperties": true
    },
    "overall": {
      "type": "object",
      "required": ["result", "counts"],
      "properties": {
        "result": {"type": "string", "enum": ["PASS", "FAIL"]},
        "counts": {
          "type": "object",
          "required": ["PASS", "FAIL", "BLOCKED"],
          "properties": {
            "PASS": {"type": "integer"},
            "FAIL": {"type": "integer"},
            "BLOCKED": {"type": "integer"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section", "status", "reason", "suggested_fix"],
        "properties": {
          "section": {"type": "string"},
          "status": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]},
          "reason": {"type": "string"},
          "suggested_fix": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["status", "summary", "numeric_evidence", "evidence", "subchecks"],
      "properties": {
        "status": {"type": "string", "enum": ["PASS", "FAIL", "BLOCKED"]},
        "summary": {"type": "string"},
        "blocked_reason": {"type": "string"},
        "numeric_evidence": {"type": "object"},
        "evidence": {"type": "object"},
        "subchecks": {"type": "object"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
